{
  "name": "x-port",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "xport": "./dist/index.js"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:cli && npm run build:web",
    "build:cli": "tsc -p tsconfig.build.json && node scripts/fix-dist-imports.mjs",
    "build:web": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "dependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "better-sqlite3": "^11.9.0",
    "commander": "^12.1.0",
    "next": "^16.0.10",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3"
  }
}
